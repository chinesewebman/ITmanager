# Network Monitor Platform - Environment Variables
# Copy this file to .env and fill in the values

# ==================== Server ====================
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
SERVER_MODE=debug

# ==================== Database ====================
DB_HOST=localhost
DB_PORT=5432
DB_USER=nmp
DB_PASSWORD=nmp123
DB_NAME=network_monitor
DB_SSLMODE=disable

# ==================== Redis ====================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ==================== JWT Authentication ====================
JWT_SECRET=your-jwt-secret-key-change-in-production
JWT_EXPIRE=86400

# ==================== LDAP (Optional) ====================
LDAP_ENABLED=false
LDAP_HOST=ldap://localhost
LDAP_PORT=389
LDAP_BASE_DN=dc=company,dc=com
LDAP_BIND_DN=cn=admin,dc=company,dc=com
LDAP_BIND_PASSWORD=

# ==================== NetBox Integration ====================
NETBOX_URL=http://localhost:8000
NETBOX_TOKEN=your-netbox-api-token

# ==================== Zabbix Integration ====================
ZABBIX_URL=http://localhost:8081
ZABBIX_USER=Admin
ZABBIX_PASSWORD=zabbix

# ==================== GLPI Integration ====================
GLPI_URL=http://localhost
GLPI_APP_TOKEN=your-glpi-app-token
GLPI_USER_TOKEN=your-glpi-user-token

# ==================== Notifications ====================
DINGTALK_ENABLED=false
DINGTALK_WEBHOOK_URL=
DINGTALK_SECRET=

EMAIL_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=nmp@company.com

# ==================== Logging ====================
LOG_LEVEL=debug
LOG_FORMAT=json
LOG_OUTPUT=stdout
LOG_FILE_PATH=./logs/app.log
LOG_FILE_MAX_SIZE=100
LOG_FILE_MAX_BACKUPS=7