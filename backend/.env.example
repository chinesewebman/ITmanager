# Network Monitor Platform - Environment Variables
# Copy to .env and fill values. F1+F3: 必须用 NMP_ 前缀覆盖 config.yaml
# 启动时 config.Validate() 会校验 NMP_AUTH_JWT_SECRET 长度 >= 32

# ==================== Server ====================
NMP_SERVER_HOST=0.0.0.0
NMP_SERVER_PORT=8080
NMP_SERVER_MODE=debug

# ==================== Database ====================
NMP_DATABASE_HOST=localhost
NMP_DATABASE_PORT=5432
NMP_DATABASE_USER=nmp
# F1: dev 默认 nmp123，但 release 模式 config.Validate() 会拒绝
NMP_DATABASE_PASSWORD=dev-only-change-in-prod
NMP_DATABASE_NAME=network_monitor
NMP_DATABASE_SSLMODE=disable

# ==================== Redis ====================
NMP_REDIS_HOST=localhost
NMP_REDIS_PORT=6379
NMP_REDIS_PASSWORD=
NMP_REDIS_DB=0

# ==================== JWT (F3 必填) ====================
# 长度必须 >= 32 字符且不含占位值
# 生成命令：openssl rand -hex 32
NMP_AUTH_JWT_SECRET=please-replace-with-openssl-rand-hex-32-output-aaaaaaaaaa
NMP_AUTH_JWT_EXPIRE=86400

# ==================== LDAP (Optional) ====================
NMP_AUTH_LDAP_ENABLED=false

# ==================== NetBox Integration ====================
# F1: release 模式 NMP_INTEGRATIONS_NETBOX_TOKEN 必填
NMP_INTEGRATIONS_NETBOX_URL=http://localhost:8000
NMP_INTEGRATIONS_NETBOX_TOKEN=dev-netbox-token

# ==================== Zabbix Integration ====================
NMP_INTEGRATIONS_ZABBIX_URL=http://localhost:8081
NMP_INTEGRATIONS_ZABBIX_USER=Admin
NMP_INTEGRATIONS_ZABBIX_PASSWORD=zabbix

# ==================== GLPI Integration ====================
# F1: release 模式两个 token 都必填
NMP_INTEGRATIONS_GLPI_URL=http://localhost
NMP_INTEGRATIONS_GLPI_APP_TOKEN=dev-glpi-app-token
NMP_INTEGRATIONS_GLPI_USER_TOKEN=dev-glpi-user-token

# ==================== Notifications ====================
# 留空

# ==================== Logging ====================
NMP_LOG_LEVEL=debug
NMP_LOG_FORMAT=json
